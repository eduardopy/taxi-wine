---
import { site } from '../site.config';

interface Props {
  prefix?: string;
  label?: string;
}

const {
  prefix = 'Mendoza · Turismo',
  label = 'Authorized Mendoza tourism vehicle',
} = Astro.props;
---

<span class="plate" aria-label={`${label}, plate ${site.vehiclePlate}`}>
  <span>{prefix}</span>
  <span class="plate__dot" aria-hidden="true"></span>
  <span class="plate__num">{site.vehiclePlate}</span>
</span>
