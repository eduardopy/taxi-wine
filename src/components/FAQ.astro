---
import { getContent, type Locale } from '../site.config';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const t = getContent(locale);
---

<section
  id="faq"
  class="relative py-20 md:py-32"
  style="background: var(--color-cream-2);"
>
  <div class="container-x">
    <div class="grid grid-cols-12 gap-8 md:gap-12">
      <div class="col-span-12 md:col-span-5">
        <p class="eyebrow mb-5">{t.faqSection.eyebrow}</p>
        <h2 class="text-4xl md:text-6xl mb-6">
          {t.faqSection.headingBefore}
          <span class="italic-display" style="color: var(--color-wine);"> {t.faqSection.headingAccent}</span>
        </h2>
        <p style="color: var(--color-mute);" class="max-w-sm">
          {t.faqSection.intro}
        </p>
      </div>

      <div class="col-span-12 md:col-span-7">
        <div class="border-t" style="border-color: var(--color-line);">
          {t.faqs.map((item) => (
            <details class="group border-b py-5" style="border-color: var(--color-line);">
              <summary class="cursor-pointer flex items-center justify-between gap-4 list-none">
                <span
                  class="text-xl md:text-2xl pr-4"
                  style="font-family: var(--font-display);"
                >
                  {item.q}
                </span>
                <span
                  aria-hidden="true"
                  class="text-2xl transition-transform group-open:rotate-45 shrink-0"
                  style="color: var(--color-wine);"
                >+</span>
              </summary>
              <p
                class="mt-4 max-w-2xl leading-relaxed"
                style="color: var(--color-ink);"
              >
                {item.a}
              </p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
