---
import { contact } from '../site.config';
---

<section id="contact" class="relative py-20 md:py-32">
  <div class="container-x">
    <div class="grid grid-cols-12 gap-8 md:gap-16">
      <!-- Left: pitch -->
      <div class="col-span-12 md:col-span-5">
        <p class="eyebrow mb-5">Plan your day</p>
        <h2 class="text-4xl md:text-6xl mb-8">
          Tell me your <span class="italic-display" style="color: var(--color-wine);">dates.</span>
        </h2>
        <p class="text-lg max-w-md mb-10" style="color: var(--color-mute);">
          A few sentences are enough — when you're arriving, how many of you, what kind of
          day you want. I reply the same day with a plan and a price.
        </p>

        <!-- Direct contacts -->
        <div class="space-y-4">
          <a
            href={`https://wa.me/${contact.whatsapp}?text=${encodeURIComponent(
              "Hi! I'd like to plan a wine day in Mendoza."
            )}`}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-whatsapp w-full justify-between"
          >
            <span class="flex items-center gap-2.5">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347zM12.04 21.785h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884zm8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              WhatsApp
            </span>
            <span style="opacity: 0.85;">{contact.whatsappDisplay}</span>
          </a>

          <a
            href={`mailto:${contact.email}?subject=${encodeURIComponent('Mendoza wine day inquiry')}`}
            class="btn btn-outline w-full justify-between"
          >
            <span>Email</span>
            <span style="color: var(--color-mute);">{contact.email}</span>
          </a>

          {contact.instagram && (
            <a
              href={`https://instagram.com/${contact.instagram}`}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-outline w-full justify-between"
            >
              <span>Instagram</span>
              <span style="color: var(--color-mute);">@{contact.instagram}</span>
            </a>
          )}
        </div>
      </div>

      <!-- Right: form -->
      <div class="col-span-12 md:col-span-7">
        <form
          action={`mailto:${contact.email}`}
          method="POST"
          enctype="text/plain"
          class="card"
          style="padding: 2rem md:3rem;"
        >
          <p class="eyebrow mb-6">Booking request</p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
            <label class="block">
              <span class="block text-sm mb-1.5" style="color: var(--color-mute);">Your name</span>
              <input
                type="text"
                name="name"
                required
                class="w-full px-4 py-3 bg-transparent border focus:outline-none focus:ring-1 transition"
                style="border-color: var(--color-line); color: var(--color-ink);"
              />
            </label>

            <label class="block">
              <span class="block text-sm mb-1.5" style="color: var(--color-mute);">WhatsApp / phone</span>
              <input
                type="tel"
                name="phone"
                class="w-full px-4 py-3 bg-transparent border focus:outline-none focus:ring-1 transition"
                style="border-color: var(--color-line); color: var(--color-ink);"
              />
            </label>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
            <label class="block">
              <span class="block text-sm mb-1.5" style="color: var(--color-mute);">Travel dates</span>
              <input
                type="text"
                name="dates"
                placeholder="e.g. March 12–15"
                class="w-full px-4 py-3 bg-transparent border focus:outline-none focus:ring-1 transition"
                style="border-color: var(--color-line); color: var(--color-ink);"
              />
            </label>

            <label class="block">
              <span class="block text-sm mb-1.5" style="color: var(--color-mute);">Guests</span>
              <input
                type="number"
                name="guests"
                min="1"
                max="6"
                class="w-full px-4 py-3 bg-transparent border focus:outline-none focus:ring-1 transition"
                style="border-color: var(--color-line); color: var(--color-ink);"
              />
            </label>
          </div>

          <label class="block mb-6">
            <span class="block text-sm mb-1.5" style="color: var(--color-mute);">
              What kind of day are you imagining?
            </span>
            <textarea
              name="message"
              rows="4"
              placeholder="Big lunch with views, biodynamic wines, our first time in Mendoza, etc."
              class="w-full px-4 py-3 bg-transparent border focus:outline-none focus:ring-1 transition resize-none"
              style="border-color: var(--color-line); color: var(--color-ink);"
            ></textarea>
          </label>

          <button type="submit" class="btn btn-primary w-full justify-center">
            Send request
            <span aria-hidden="true">→</span>
          </button>

          <p class="text-xs mt-5 text-center" style="color: var(--color-mute);">
            This form opens your email app. For an instant reply, use WhatsApp.
          </p>
        </form>
      </div>
    </div>
  </div>
</section>
