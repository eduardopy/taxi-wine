---
import { contact, getContent, type Locale } from '../site.config';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const t = getContent(locale);
---

<section
  id="routes"
  class="relative py-20 md:py-32"
  style="background: var(--color-cream-2);"
>
  <div class="container-x">
    <div class="grid grid-cols-12 gap-6 mb-14 md:mb-20">
      <div class="col-span-12 md:col-span-7">
        <p class="eyebrow mb-5">{t.routesSection.eyebrow}</p>
        <h2 class="text-4xl md:text-6xl">
          {t.routesSection.heading}
          <span class="italic-display" style="color: var(--color-wine);"> {t.routesSection.headingAccent}</span>
        </h2>
      </div>
      <div class="col-span-12 md:col-span-4 md:col-start-9 self-end">
        <p style="color: var(--color-mute);" class="text-base">
          {t.routesSection.intro}
        </p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-px" style="background: var(--color-line);">
      {t.routes.map((route) => (
        <article class="group flex flex-col" style="background: var(--color-cream);">
          <div class="aspect-[16/10] overflow-hidden">
            <img
              src={route.image}
              alt={`${route.title} ${t.routesSection.imageAltSuffix}`}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
          </div>

          <div class="p-7 md:p-8 flex flex-col flex-1">
            <p class="eyebrow mb-4">{route.eyebrow}</p>
            <h3 class="text-3xl md:text-4xl mb-2">{route.title}</h3>
            <p class="text-sm mb-5" style="color: var(--color-mute);">{route.drive}</p>
            <p class="mb-7 leading-relaxed" style="color: var(--color-ink);">
              {route.bestFor}
            </p>

            <div class="mt-auto border-t pt-5" style="border-color: var(--color-line);">
              <p class="eyebrow mb-4">{t.routesSection.rhythmLabel}</p>
              <ol class="space-y-3">
                {route.rhythm.map((item, i) => (
                  <li class="flex gap-3 text-sm leading-relaxed" style="color: var(--color-mute);">
                    <span class="section-num shrink-0 text-lg">
                      {String(i + 1).padStart(2, '0')}
                    </span>
                    <span>{item}</span>
                  </li>
                ))}
              </ol>
            </div>

            <a
              href={`https://wa.me/${contact.whatsapp}?text=${encodeURIComponent(
                `${t.routesSection.whatsappInterest} ${route.title}.`
              )}`}
              class="btn btn-outline mt-7 text-sm justify-center max-w-full whitespace-normal"
              target="_blank"
              rel="noopener noreferrer"
            >
              {t.routesSection.ask} {route.title}
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
