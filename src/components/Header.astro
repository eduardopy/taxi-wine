---
import { site, contact } from '../site.config';
---

<header class="relative z-20 border-b" style="border-color: var(--color-line);">
  <div class="container-x flex items-center justify-between py-5 md:py-6">
    <!-- Logo -->
    <a href="/" class="flex items-baseline gap-2 group">
      <span
        class="text-2xl md:text-[1.6rem] tracking-tight"
        style="font-family: var(--font-display); font-weight: 500;"
      >
        {site.brand}
      </span>
      <span
        class="hidden sm:inline italic-display text-sm"
        style="color: var(--color-terracotta); font-family: var(--font-display);"
      >
        Mendoza
      </span>
    </a>

    <!-- Nav -->
    <nav class="hidden md:flex items-center gap-8 text-sm">
      <a href="#services" class="hover:opacity-60 transition-opacity">Services</a>
      <a href="#routes" class="hover:opacity-60 transition-opacity">Routes</a>
      <a href="#experiences" class="hover:opacity-60 transition-opacity">Experiences</a>
      <a href="#about" class="hover:opacity-60 transition-opacity">About</a>
      <a href="#faq" class="hover:opacity-60 transition-opacity">FAQ</a>
    </nav>

    <a href="#contact" class="btn btn-primary text-sm">
      Book a ride
      <span aria-hidden="true">→</span>
    </a>
  </div>
</header>
