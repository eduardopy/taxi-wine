---
import { getContent, localeMeta, locales, site, type Locale } from '../site.config';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const t = getContent(locale);
---

<header class="relative z-20 border-b" style="border-color: var(--color-line);">
  <div class="container-x flex items-center justify-between gap-4 py-5 md:py-6">
    <a href={localeMeta[locale].path} class="flex items-baseline gap-2 group shrink-0">
      <span
        class="text-2xl md:text-[1.6rem] tracking-tight"
        style="font-family: var(--font-display); font-weight: 500;"
      >
        {site.brand}
      </span>
      <span
        class="hidden sm:inline italic-display text-sm"
        style="color: var(--color-terracotta); font-family: var(--font-display);"
      >
        Mendoza
      </span>
    </a>

    <nav class="hidden lg:flex items-center gap-8 text-sm">
      <a href="#services" class="hover:opacity-60 transition-opacity">{t.nav.services}</a>
      <a href="#routes" class="hover:opacity-60 transition-opacity">{t.nav.routes}</a>
      <a href="#experiences" class="hover:opacity-60 transition-opacity">{t.nav.experiences}</a>
      <a href="#about" class="hover:opacity-60 transition-opacity">{t.nav.about}</a>
      <a href="#faq" class="hover:opacity-60 transition-opacity">{t.nav.faq}</a>
    </nav>

    <div class="flex items-center gap-3">
      <nav class="hidden sm:flex items-center gap-2 text-xs" aria-label={t.footer.languages}>
        {locales.map((item) => (
          <a
            href={localeMeta[item].path}
            class="px-2 py-1 border transition-opacity hover:opacity-60"
            style={`border-color: var(--color-line); color: ${item === locale ? 'var(--color-wine)' : 'var(--color-mute)'};`}
            aria-current={item === locale ? 'page' : undefined}
          >
            {localeMeta[item].label}
          </a>
        ))}
      </nav>

      <a href="#contact" class="btn btn-primary text-sm">
        {t.nav.book}
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>

  <nav class="container-x sm:hidden flex items-center gap-2 pb-4 text-xs" aria-label={t.footer.languages}>
    {locales.map((item) => (
      <a
        href={localeMeta[item].path}
        class="px-2 py-1 border transition-opacity hover:opacity-60"
        style={`border-color: var(--color-line); color: ${item === locale ? 'var(--color-wine)' : 'var(--color-mute)'};`}
        aria-current={item === locale ? 'page' : undefined}
      >
        {localeMeta[item].name}
      </a>
    ))}
  </nav>
</header>
