---
import { fitSelector } from '../site.config';
import LicensePlate from './LicensePlate.astro';

const { yes, no, closer } = fitSelector;
---

<section
  class="relative py-20 md:py-28"
  style="background: var(--color-cream-2); border-block: 1px solid var(--color-line);"
>
  <div class="container-x">
    <div class="max-w-3xl mb-14 md:mb-16">
      <p class="eyebrow mb-5">Honest fit</p>
      <h2 class="text-4xl md:text-6xl">
        When this is the
        <span class="italic-display" style="color: var(--color-wine);">right call</span>,
        and when it isn't.
      </h2>
      <p class="mt-6 text-base md:text-lg max-w-2xl" style="color: var(--color-mute);">
        I'm one driver with one taxi. Great for some trips, wrong for others — here's the difference, plainly.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-px" style="background: var(--color-line);">
      <!-- YES column -->
      <div class="p-8 md:p-10" style="background: var(--color-cream);">
        <div class="mb-5">
          <LicensePlate />
        </div>
        <h3 class="text-2xl md:text-[1.7rem] mb-1 leading-tight">{yes.label}</h3>
        <p class="text-sm mb-7" style="color: var(--color-mute);">{yes.sub}</p>
        <ul class="space-y-4">
          {yes.points.map((p) => (
            <li class="flex gap-3 text-[0.97rem] leading-relaxed">
              <span
                aria-hidden="true"
                class="mt-[0.55em] shrink-0 inline-block w-2 h-2 rounded-full"
                style="background: var(--color-wine);"
              ></span>
              <span>{p}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- NO column -->
      <div class="p-8 md:p-10" style="background: var(--color-cream);">
        <div class="mb-5">
          <span
            class="eyebrow"
            style="color: var(--color-mute); --tw-bg-opacity: 1;"
          >
            Not me — and that's fine
          </span>
        </div>
        <h3
          class="text-2xl md:text-[1.7rem] mb-1 leading-tight"
          style="color: var(--color-mute);"
        >
          {no.label}
        </h3>
        <p class="text-sm mb-7" style="color: var(--color-mute);">{no.sub}</p>
        <ul class="space-y-4">
          {no.points.map((p) => (
            <li class="flex gap-3 text-[0.97rem] leading-relaxed" style="color: var(--color-mute);">
              <span
                aria-hidden="true"
                class="mt-[0.55em] shrink-0 inline-block w-2 h-[1px]"
                style="background: var(--color-mute);"
              ></span>
              <span>{p}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <p class="mt-10 text-base md:text-lg max-w-2xl italic-display" style="color: var(--color-ink);">
      {closer}
    </p>
  </div>
</section>
