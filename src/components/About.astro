---
import { site } from '../site.config';
---

<section
  id="about"
  class="relative py-20 md:py-32"
  style="background: var(--color-cream-2);"
>
  <div class="container-x">
    <div class="grid grid-cols-12 gap-8 md:gap-16 items-start">
      <!-- Photo collage -->
      <div class="col-span-12 md:col-span-5">
        <div class="relative">
          <div class="aspect-[4/5] w-full overflow-hidden">
            <img
              src="/img/guests-cellar.webp"
              alt="Matías with guests tasting wine in a Mendoza cellar"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>

          <!-- Small inset of the actual taxi -->
          <div
            class="absolute -bottom-5 -right-5 md:-bottom-7 md:-right-7 w-1/2 aspect-square overflow-hidden border-4 hidden sm:block"
            style="border-color: var(--color-cream-2); box-shadow: 0 18px 40px -18px rgba(26, 22, 18, 0.4);"
          >
            <img
              src="/img/taxi-winery.webp"
              alt="The Taxi Wine vehicle parked at a Mendoza winery"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>

      <!-- Copy -->
      <div class="col-span-12 md:col-span-7 md:pl-4">
        <p class="eyebrow mb-5">About</p>
        <h2 class="text-4xl md:text-6xl mb-8">
          Hi, I'm <span class="italic-display" style="color: var(--color-wine);">{site.driverName}</span>.
          <br />The whole company.
        </h2>

        <div class="space-y-5 text-base md:text-lg max-w-2xl" style="color: var(--color-ink);">
          <p>
            I was born in Mendoza, and I spend my days driving visitors between the city,
            the vineyards, and the mountains. The job is part logistics, part local advice:
            which routes make sense, where to leave enough time for lunch, and when a long
            drive is actually worth it.
          </p>

          <p>
            I'm a <strong>licensed Mendoza city taxi driver</strong> — yes, an actual taxi (plate {site.vehiclePlate}).
            That's the trick: officially regulated, properly insured, and priced fairly because I'm
            not running a grey-market tour van. You get the same care a private driver gives, with
            the legitimacy of a city-licensed cab.
          </p>

          <p>
            Most days I drive a couple, occasionally a small group, sometimes a single
            traveler who doesn't want to be on a bus. There's no fleet, no dispatcher, no
            handing you off — when you book Taxi Wine, I'm the person who shows up.
          </p>
        </div>

        <!-- Quick facts -->
        <dl class="mt-10 grid grid-cols-2 sm:grid-cols-3 gap-y-6 gap-x-8 max-w-xl">
          <div>
            <dt class="eyebrow mb-1.5">Languages</dt>
            <dd style="font-family: var(--font-display); font-size: 1.25rem;">EN · ES</dd>
          </div>
          <div>
            <dt class="eyebrow mb-1.5">Vehicle</dt>
            <dd style="font-family: var(--font-display); font-size: 1.15rem;">Chevrolet Classic</dd>
          </div>
          <div>
            <dt class="eyebrow mb-1.5">Capacity</dt>
            <dd style="font-family: var(--font-display); font-size: 1.25rem;">4 + luggage</dd>
          </div>
        </dl>
      </div>
    </div>
  </div>
</section>
