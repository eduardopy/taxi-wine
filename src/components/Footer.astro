---
import { contact, getContent, localeMeta, locales, site, withBase, type Locale } from '../site.config';
import LicensePlate from './LicensePlate.astro';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const t = getContent(locale);
const year = new Date().getFullYear();
---

<footer
  class="relative border-t pt-14 md:pt-20 pb-10"
  style="border-color: var(--color-line); background: var(--color-cream);"
>
  <div class="container-x">
    <div class="grid grid-cols-12 gap-8 mb-14 md:mb-20">
      <div class="col-span-12 md:col-span-6">
        <p
          class="text-3xl md:text-4xl mb-3"
          style="font-family: var(--font-display);"
        >
          {site.brand}
        </p>
        <p
          class="italic-display text-xl md:text-2xl max-w-md mb-6"
          style="color: var(--color-wine);"
        >
          {t.tagline}.
        </p>
        <LicensePlate prefix={t.licensePlate.prefix} label={t.licensePlate.aria} />
      </div>

      <div class="col-span-6 md:col-span-2">
        <p class="eyebrow mb-4">{t.footer.siteLabel}</p>
        <ul class="space-y-2 text-base">
          <li><a href="#services" class="hover:opacity-60 transition-opacity">{t.nav.services}</a></li>
          <li><a href="#routes" class="hover:opacity-60 transition-opacity">{t.nav.routes}</a></li>
          <li><a href="#experiences" class="hover:opacity-60 transition-opacity">{t.nav.experiences}</a></li>
          <li><a href="#about" class="hover:opacity-60 transition-opacity">{t.nav.about}</a></li>
          <li><a href="#process" class="hover:opacity-60 transition-opacity">{t.footer.howItWorks}</a></li>
          <li><a href="#faq" class="hover:opacity-60 transition-opacity">{t.nav.faq}</a></li>
        </ul>
      </div>

      <div class="col-span-6 md:col-span-2">
        <p class="eyebrow mb-4">{t.footer.contactLabel}</p>
        <ul class="space-y-2 text-base">
          <li>
            <a
              href={`https://wa.me/${contact.whatsapp}`}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:opacity-60 transition-opacity"
            >
              WhatsApp
            </a>
          </li>
          <li>
            <a href={`mailto:${contact.email}`} class="hover:opacity-60 transition-opacity">
              Email
            </a>
          </li>
          {contact.instagram && (
            <li>
              <a
                href={`https://instagram.com/${contact.instagram}`}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:opacity-60 transition-opacity"
              >
                Instagram
              </a>
            </li>
          )}
        </ul>
      </div>

      <div class="col-span-12 md:col-span-2">
        <p class="eyebrow mb-4">{t.footer.languages}</p>
        <ul class="flex flex-wrap md:block gap-2 md:space-y-2 text-base">
          {locales.map((item) => (
            <li>
              <a
                href={withBase(localeMeta[item].path)}
                class="hover:opacity-60 transition-opacity"
                style={item === locale ? 'color: var(--color-wine);' : ''}
                aria-current={item === locale ? 'page' : undefined}
              >
                {localeMeta[item].name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="hairline mb-6" style="background: var(--color-line);"></div>

    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
      <p class="text-sm" style="color: var(--color-mute);">
        © {year} {site.brand}. {site.baseLocation}.
      </p>
      <p class="eyebrow" style="color: var(--color-mute);">{t.footer.made}</p>
    </div>
  </div>
</footer>
