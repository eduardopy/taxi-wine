---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from './Header.astro';
import Hero from './Hero.astro';
import Services from './Services.astro';
import Routes from './Routes.astro';
import About from './About.astro';
import FitSelector from './FitSelector.astro';
import WhyChoose from './WhyChoose.astro';
import Experiences from './Experiences.astro';
import Gallery from './Gallery.astro';
import Process from './Process.astro';
import Reviews from './Reviews.astro';
import FAQ from './FAQ.astro';
import Contact from './Contact.astro';
import Footer from './Footer.astro';
import WhatsAppFloat from './WhatsAppFloat.astro';
import type { Locale } from '../site.config';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<BaseLayout locale={locale}>
  <Header locale={locale} />
  <main>
    <Hero locale={locale} />
    <Services locale={locale} />
    <Routes locale={locale} />
    <About locale={locale} />
    <FitSelector locale={locale} />
    <WhyChoose locale={locale} />
    <Experiences locale={locale} />
    <Gallery locale={locale} />
    <Process locale={locale} />
    <Reviews locale={locale} />
    <FAQ locale={locale} />
    <Contact locale={locale} />
  </main>
  <Footer locale={locale} />
  <WhatsAppFloat locale={locale} />
</BaseLayout>
