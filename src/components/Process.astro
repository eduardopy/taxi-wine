---
import { getContent, type Locale } from '../site.config';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const t = getContent(locale);
---

<section
  id="process"
  class="relative py-20 md:py-32"
  style="background: var(--color-ink); color: var(--color-cream);"
>
  <div class="container-x">
    <div class="max-w-3xl mb-14 md:mb-20">
      <p class="eyebrow mb-5" style="color: var(--color-cream-2); opacity: 0.7;">
        {t.processSection.eyebrow}
      </p>
      <h2 class="text-4xl md:text-6xl" style="color: var(--color-cream);">
        {t.processSection.headingBefore}
        <span class="italic-display" style="color: var(--color-terracotta);"> {t.processSection.headingAccent}</span>
        {t.processSection.headingAfter}
      </h2>
    </div>

    <ol class="grid grid-cols-1 md:grid-cols-3 gap-px" style="background: rgba(246, 239, 226, 0.15);">
      {t.process.map((step) => (
        <li
          class="relative p-8 md:p-10"
          style="background: var(--color-ink);"
        >
          <span
            class="block mb-8"
            style="font-family: var(--font-display); font-style: italic; font-size: 3rem; color: var(--color-terracotta); line-height: 1;"
          >
            {step.n}
          </span>
          <h3 class="text-2xl md:text-3xl mb-4" style="color: var(--color-cream);">
            {step.title}
          </h3>
          <p style="color: var(--color-cream-2); opacity: 0.8;" class="leading-relaxed">
            {step.body}
          </p>
        </li>
      ))}
    </ol>
  </div>
</section>
