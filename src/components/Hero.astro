---
import { getContent, withBase, type Locale } from '../site.config';
import LicensePlate from './LicensePlate.astro';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;
const t = getContent(locale);
---

<section class="relative overflow-hidden">
  <div class="taxi-stripe" aria-hidden="true"></div>

  <div class="container-x pt-12 md:pt-16 pb-16 md:pb-24">
    <div class="grid grid-cols-12 gap-6 md:gap-10 items-end">
      <div class="col-span-12 lg:col-span-7 rise rise-1">
        <div class="mb-6">
          <LicensePlate prefix={t.licensePlate.prefix} label={t.licensePlate.aria} />
        </div>

        <h1 class="text-[2.6rem] sm:text-6xl md:text-7xl lg:text-[5rem] leading-[1.02]">
          {t.hero.titleTop}<br />
          <span class="italic-display" style="color: var(--color-wine);">
            {t.hero.titleAccent}
          </span>
        </h1>

        <p
          class="text-base md:text-lg max-w-xl mt-8"
          style="color: var(--color-mute); line-height: 1.55;"
        >
          {t.hero.descriptionBefore}
          <em class="italic-display" style="color: var(--color-ink);">{t.hero.descriptionEmphasis}</em>
          {t.hero.descriptionAfter}
        </p>
      </div>

      <div class="col-span-12 lg:col-span-5 rise rise-2">
        <div class="relative aspect-square">
          <div
            class="absolute inset-0 overflow-hidden"
            style="background: var(--color-wine);"
          >
            <img
              src={withBase('/img/scene-vineyard-andes.webp')}
              alt={t.hero.mainImageAlt}
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>

          <div
            class="absolute -bottom-6 -left-6 w-2/5 aspect-square overflow-hidden border-4 hidden sm:block"
            style="border-color: var(--color-cream); box-shadow: 0 18px 40px -18px rgba(26, 22, 18, 0.4);"
          >
            <img
              src={withBase('/img/car-front.jpg')}
              alt={t.hero.taxiImageAlt}
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-3 mt-14 md:mt-20 rise rise-3">
      <a href="#services" class="btn btn-primary">
        {t.hero.ctaPrimary}
        <span aria-hidden="true">→</span>
      </a>
      <a href="#contact" class="btn btn-outline">{t.hero.ctaSecondary}</a>
    </div>

    <div
      class="mt-16 md:mt-24 grid grid-cols-2 md:grid-cols-4 gap-y-8 gap-x-6 pt-8 border-t rise rise-4"
      style="border-color: var(--color-line);"
    >
      {t.hero.stats.map((stat) => (
        <div>
          <p class="eyebrow mb-2">{stat.eyebrow}</p>
          <p class="text-2xl md:text-3xl" style="font-family: var(--font-display);">
            {stat.value}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
