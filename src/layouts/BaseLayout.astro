---
import '../styles/global.css';
import {
  contact,
  defaultLocale,
  getContent,
  localeMeta,
  locales,
  site,
  withBase,
  type Locale,
} from '../site.config';

interface Props {
  locale?: Locale;
  title?: string;
  description?: string;
}

const {
  locale = 'en',
  title,
  description,
} = Astro.props;

const t = getContent(locale);
const pageTitle = title ?? t.meta.title;
const pageDescription = description ?? t.meta.description;
const configuredSite = Astro.site ?? new URL(`https://${site.domain}`);
const siteOrigin = configuredSite.toString().replace(/\/$/, '');
const absoluteUrl = (path: string) => new URL(withBase(path), `${siteOrigin}/`).toString();
const siteUrl = absoluteUrl('/');
const currentUrl = absoluteUrl(localeMeta[locale].path);

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['LocalBusiness', 'TravelAgency'],
      '@id': `${siteUrl}#business`,
      name: site.brand,
      description: pageDescription,
      url: siteUrl,
      image: absoluteUrl('/img/car-front.jpg'),
      telephone: contact.whatsappDisplay,
      email: contact.email,
      areaServed: [
        { '@type': 'City', name: 'Mendoza' },
        { '@type': 'AdministrativeArea', name: 'Luján de Cuyo' },
        { '@type': 'AdministrativeArea', name: 'Maipú' },
        { '@type': 'AdministrativeArea', name: 'Valle de Uco' },
      ],
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Mendoza',
        addressRegion: 'Mendoza',
        addressCountry: 'AR',
      },
      sameAs: [`https://instagram.com/${contact.instagram}`],
      priceRange: '$$',
      knowsLanguage: site.languages,
      vehicle: {
        '@type': 'Vehicle',
        name: site.vehicle,
        identifier: site.vehiclePlate,
        seatingCapacity: 4,
      },
    },
    ...t.services.map((s) => ({
      '@type': 'Service',
      '@id': `${siteUrl}#service-${s.id}-${locale}`,
      name: `${s.title} — Mendoza private driver`,
      description: s.blurb,
      provider: { '@id': `${siteUrl}#business` },
      areaServed: { '@type': 'City', name: 'Mendoza' },
      offers: {
        '@type': 'Offer',
        price: s.price,
        priceCurrency: 'USD',
        availability: 'https://schema.org/InStock',
      },
    })),
    ...t.routes.map((route) => ({
      '@type': 'TouristTrip',
      '@id': `${siteUrl}#route-${route.id}-${locale}`,
      name: `${route.title} wine route with private driver`,
      description: route.bestFor,
      provider: { '@id': `${siteUrl}#business` },
      touristType: 'Wine tourist',
      itinerary: route.rhythm.join(' | '),
    })),
  ],
};
---

<!doctype html>
<html lang={localeMeta[locale].htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={currentUrl} />
    {locales.map((item) => (
      <link rel="alternate" hreflang={localeMeta[item].htmlLang} href={absoluteUrl(localeMeta[item].path)} />
    ))}
    <link rel="alternate" hreflang="x-default" href={absoluteUrl(localeMeta[defaultLocale].path)} />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={currentUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />

    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />
  </body>
</html>
